# ----------------------------------
# Text normalization
# ----------------------------------
# Automatically detect text files and normalize line endings
* text=auto

# Force LF line endings for important source files (cross-platform consistency)
*.cs text eol=lf
*.shader text eol=lf
*.cginc text eol=lf
*.compute text eol=lf
*.hlsl text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Shell scripts (important for Linux/macOS environments)
*.sh text eol=lf

# ---------------------------------------
# Unity Smart Merge (VERY IMPORTANT)
# ---------------------------------------
# Use UnityYAMLMerge for scene, prefab, and asset files
*.unity merge=unityyamlmerge
*.prefab merge=unityyamlmerge
*.asset merge=unityyamlmerge
*.meta merge=unityyamlmerge

# ---------------------------------------
# Binary files (non-mergeable)
# ---------------------------------------
# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.tga binary
*.psd binary

# Audio
*.wav binary
*.mp3 binary
*.ogg binary

# 3D models
*.fbx binary
*.obj binary
*.blend binary

# Video
*.mp4 binary
*.mov binary

# ---------------------------------------
# Disable useless diffs for binary files
# ---------------------------------------
*.png -diff
*.jpg -diff
*.jpeg -diff
*.wav -diff
*.mp3 -diff
*.fbx -diff